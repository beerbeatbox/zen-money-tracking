# ================================
# Android Platform .gitignore
# ================================

# ===================
# Gradle
# ===================
gradle-wrapper.jar
/.gradle
/gradle/
!gradle/wrapper/gradle-wrapper.properties

# Gradle build files
/build/
**/build/
local.properties

# Gradle wrapper scripts (regenerated by Flutter)
/gradlew
/gradlew.bat

# ===================
# Build Outputs
# ===================
/captures/
/app/debug/
/app/profile/
/app/release/

# ===================
# Generated Files
# ===================
GeneratedPluginRegistrant.java
GeneratedPluginRegistrant.kt

# Native build
.cxx/
.externalNativeBuild/
/ndkBuild/
/cmake/

# ===================
# Signing & Security
# ===================
# NEVER commit signing keys or properties!
key.properties
*.keystore
*.jks
*.p12
*.pem
upload-keystore.jks
release-keystore.jks

# Google Services (contains API keys)
google-services.json
app/google-services.json

# ===================
# IDE Files
# ===================
# Android Studio
*.iml
.idea/
*.swp
*~

# ===================
# Proguard
# ===================
proguard-rules.pro.bak
mapping.txt
seeds.txt
usage.txt

# ===================
# Testing
# ===================
/app/test/
**/testResults/
**/test-results/
/app/androidTest/

# ===================
# Misc
# ===================
.DS_Store
*.hprof
*.log

# Lint
lint-baseline.xml
lint-results*.html
lint-results*.xml

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# Firebase
firebase-debug.log
.firebase/
